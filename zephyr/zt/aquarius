    .note { font-size: var(--text-sm); color: var(--color-text-muted); }
    .footer-note { margin-top: var(--space-4); font-size: var(--text-sm); color: var(--color-text-muted); }
    ul { margin: 0; padding-left: 1.2rem; }
    @media (max-width: 1100px) {
