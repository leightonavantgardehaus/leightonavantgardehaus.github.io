}));

const state = {
  threat: 'All', control: 'All', sensitivity: 'All', user: 'All', search: '', sortKey: 'riskScore', sortDir: 'desc'
};

const byId = id => document.getElementById(id);
const matrixBody = byId('matrixBody');
const activeFilters = byId('activeFilters');
const drawer = byId('drawer');

function riskClass(score){
  if(score >= 90) return 'risk-critical';
  if(score >= 75) return 'risk-high';
  if(score >= 60) return 'risk-med';
  return 'risk-low';
}

function populateSelect(id, values){
  const el = byId(id);
  el.innerHTML = ['All', ...values].map(v => `<option value="${v}">${v}</option>`).join('');
  el.addEventListener('change', e => {
    const keyMap = { threatFilter:'threat', controlFilter:'control', sensitivityFilter:'sensitivity', userFilter:'user' };
    state[keyMap[id]] = e.target.value;
    render();
  });
}

populateSelect('threatFilter', [...new Set(data.flatMap(d => d.threats))]);
populateSelect('controlFilter', controls.map(c => c.id));
populateSelect('sensitivityFilter', [...new Set(data.map(d => d.dataSensitivity))]);
populateSelect('userFilter', [...new Set(data.map(d => d.userType))]);
byId('searchInput').addEventListener('input', e => { state.search = e.target.value.toLowerCase(); render(); });

byId('controlLegend').innerHTML = controls.map(c => `<span class="chip">${c.id}</span>`).join('');

document.querySelectorAll('[data-sort]').forEach(btn => {
  btn.addEventListener('click', () => {
    const key = btn.dataset.sort;
    if(state.sortKey === key){ state.sortDir = state.sortDir === 'asc' ? 'desc' : 'asc'; }
    else { state.sortKey = key; state.sortDir = key === 'riskScore' ? 'desc' : 'asc'; }
    render();
  });
});

function filteredData(){
  return data.filter(row => {
    const searchBlob = [row.userType, row.dataSensitivity, row.controlType, row.priority, row.rationale, row.entraOwner, ...row.threats, ...row.controls, ...row.entraFeatures, ...row.entra].join(' ').toLowerCase();
    return (state.threat === 'All' || row.threats.includes(state.threat)) &&
           (state.control === 'All' || row.controls.includes(state.control)) &&
           (state.sensitivity === 'All' || row.dataSensitivity === state.sensitivity) &&
           (state.user === 'All' || row.userType === state.user) &&
           (!state.search || searchBlob.includes(state.search));
  }).sort((a,b) => {
    const dir = state.sortDir === 'asc' ? 1 : -1;
    let av = a[state.sortKey], bv = b[state.sortKey];
    if(Array.isArray(av)) av = av.join(', ');
    if(Array.isArray(bv)) bv = bv.join(', ');
    if(typeof av === 'number' && typeof bv === 'number') return (av - bv) * dir;
    return String(av).localeCompare(String(bv)) * dir;
  });
}

function renderKpis(rows){
  const avg = rows.length ? Math.round(rows.reduce((s,r) => s + r.riskScore, 0) / rows.length) : 0;
  const critical = rows.filter(r => r.riskScore >= 90).length;
  const featureCount = new Set(rows.flatMap(r => r.entraFeatures)).size;
  byId('kpiRows').textContent = rows.length;
  byId('kpiAvgRisk').textContent = avg;
  byId('kpiCritical').textContent = critical;
  byId('kpiFeatures').textContent = featureCount;
  byId('progressBar').style.width = avg + '%';
}

function renderActiveFilters(){
  const items = [
    ['Threat', state.threat], ['Control', state.control], ['Sensitivity', state.sensitivity], ['User', state.user]
  ].filter(([,v]) => v !== 'All');
  activeFilters.innerHTML = items.length ? items.map(([k,v]) => `<span class="chip">${k}: ${v}</span>`).join('') : '<span class="chip">No filters applied</span>';
}

function openDrawer(row){
  byId('drawerMeta').textContent = `${row.userType} · ${row.dataSensitivity}`;
  byId('drawerTitle').textContent = `${row.priority} priority · Risk ${row.riskScore}`;
  byId('drawerBody').innerHTML = `
    <section class="detail-block">
      <h4>Threat coverage</h4>
      <div class="mini-list">${row.threats.map(t => `<span class="tag threat">${t}</span>`).join('')}</div>
      <p class="note">${row.rationale}</p>
    </section>
    <section class="detail-block">
      <h4>Required controls</h4>
      <div class="mini-list">${row.controls.map(c => `<span class="tag control">${c}</span>`).join('')}</div>
      <p class="note"><strong>Entra owner:</strong> ${row.entraOwner}</p>
    </section>
    <section class="detail-block">
      <h4>Desired outcomes</h4>
      <ul>${row.outcomes.map(x => `<li>${x}</li>`).join('')}</ul>
    </section>
    <section class="detail-block">
      <h4>Microsoft Entra recommendations</h4>
      <ul>${row.entra.map(x => `<li>${x}</li>`).join('')}</ul>
    </section>
    <section class="detail-block">
      <h4>Control to Entra mapping</h4>
      <ul>${row.controls.map(c => `<li><strong>${c}:</strong> ${(entraCatalog[c] || ['Platform control']).join(', ')}</li>`).join('')}</ul>
    </section>
  `;
  drawer.classList.add('open');
  drawer.setAttribute('aria-hidden','false');
}

function render(){
  const rows = filteredData();
  renderKpis(rows);
  renderActiveFilters();
  matrixBody.innerHTML = rows.map((row, idx) => `
    <tr>
      <td><strong>${row.userType}</strong></td>
      <td>${row.dataSensitivity}</td>
      <td><div class="mini-list">${row.threats.map(t => `<span class="tag threat">${t}</span>`).join('')}</div></td>
      <td><div class="mini-list">${row.controls.map(c => `<span class="tag control">${c}</span>`).join('')}</div></td>
      <td><div class="mini-list">${row.entraFeatures.map(f => `<span class="tag entra">${f}</span>`).join('')}</div></td>
      <td>${row.controlType}</td>
      <td><span class="tag ${riskClass(row.riskScore)}">${row.riskScore}</span></td>
      <td>${row.priority}</td>
      <td><button class="btn primary" type="button" data-row="${idx}">Open</button></td>
    </tr>
  `).join('');
  [...matrixBody.querySelectorAll('[data-row]')].forEach((btn, idx) => btn.addEventListener('click', () => openDrawer(rows[idx])));
}

byId('closeDrawer').addEventListener('click', () => {
  drawer.classList.remove('open');
  drawer.setAttribute('aria-hidden','true');
});

(function(){
  const root = document.documentElement;
  let theme = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  root.setAttribute('data-theme', theme);
  byId('themeToggle').addEventListener('click', () => {
    theme = theme === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', theme);
  });
})();

render();
</script>
